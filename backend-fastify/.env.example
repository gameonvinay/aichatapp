# Backend Fastify Environment Variables

# Redis connection URL (used by Docker Compose)
REDIS_URL=redis://redis:6379

# PostgreSQL connection URL (pgvector)
POSTGRES_URL=postgresql://postgres:postgres@postgresql/paieval?sslmode=disable

# Kafka broker address (used by Docker Compose)
KAFKA_BROKERS=kafka:9092

# LM Studio URL for LLM API (OpenAI-compatible)
LM_STUDIO_URL=http://192.168.1.21:1234

# Application environment (development/production)
NODE_ENV=development